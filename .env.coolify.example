# Copy these values into Coolify's environment UI. Do not commit real secrets.
OPENAI_API_KEY=replace-with-your-openai-key
ADMIN_API_KEY=replace-with-a-long-random-secret

# Public port only used by docker-compose.local.yml.
GATEWAY_PORT=3000

# Mem0 OSS + Qdrant defaults.
QDRANT_IMAGE_TAG=v1.13.6
QDRANT_HOST=mem0-store
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=mem0
QDRANT_API_KEY=
HISTORY_DB_PATH=/app/history/history.db

# OpenAI-backed Mem0 defaults.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-nano-2025-04-14
LLM_TEMPERATURE=0.2
LLM_API_KEY=
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=text-embedding-3-small
EMBEDDER_API_KEY=

# Startup retry loop while Qdrant becomes ready.
MEM0_STARTUP_RETRIES=20
MEM0_STARTUP_DELAY_SECONDS=3
